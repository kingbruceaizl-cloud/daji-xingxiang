# 从 Supabase 项目设置中获取。
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 仅服务端使用，不能暴露给浏览器。
SUPABASE_SERVICE_ROLE_KEY=

# AI 执行模式。开发阶段默认 mock；线上真实调用必须显式设为 real。
AI_EXECUTION_MODE=mock

# 后台任务 Worker。正式环境至少配置 CRON_SECRET；不要使用示例值。
CRON_SECRET=
AI_WORKER_SECRET=
AI_WORKER_BATCH_SIZE=1

# AI 应用 1.0 默认模型通道：火山方舟（豆包），仅服务端使用。
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=
# 生图已确认优先使用 Seedream 5.0 完整版；仍以目标账号控制台显示为准。
ARK_IMAGE_MODEL_ID=doubao-seedream-5-0-260128
# 文字和视频模型在对应阶段从控制台复制，不能根据展示名称猜测。
ARK_TEXT_MODEL_ID=
ARK_VIDEO_MODEL_ID=
OPENAI_API_KEY=
JIMENG_API_KEY=
KLING_API_KEY=
TONGYI_API_KEY=

# 用于回调和绝对链接的应用地址。
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 可选：正式部署环境可设置为 production。
NEXT_PUBLIC_APP_ENV=development

# 团队内测与正式 SaaS 默认关闭公开注册，员工由后台邀请。
NEXT_PUBLIC_ALLOW_PUBLIC_SIGNUP=false
