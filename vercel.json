{
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build",
  "functions": {
    "app/api/internal/ai-worker/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/internal/ai-worker",
      "schedule": "* * * * *"
    }
  ]
}
