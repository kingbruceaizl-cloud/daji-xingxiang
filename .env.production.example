# 正式上线环境变量模板。
# 复制到 Vercel 环境变量面板，不要把真实密钥提交到代码仓库。

NEXT_PUBLIC_SUPABASE_URL=https://你的项目编号.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

SUPABASE_SERVICE_ROLE_KEY=

# 正式环境必须显式使用 real，且缺少密钥或模型 ID 时直接失败。
AI_EXECUTION_MODE=real

# Vercel Cron 会使用 CRON_SECRET 调用后台 Worker。
CRON_SECRET=
AI_WORKER_SECRET=
AI_WORKER_BATCH_SIZE=1

# AI 应用 1.0 默认模型通道：火山方舟（豆包）。
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=
ARK_IMAGE_MODEL_ID=doubao-seedream-5-0-260128
ARK_TEXT_MODEL_ID=
ARK_VIDEO_MODEL_ID=

OPENAI_API_KEY=
JIMENG_API_KEY=
KLING_API_KEY=
TONGYI_API_KEY=

NEXT_PUBLIC_APP_URL=https://你的域名
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_ALLOW_PUBLIC_SIGNUP=false
